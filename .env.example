# --- LLM ---
# Google AI Studio free-tier key: https://aistudio.google.com/
GEMINI_API_KEY=

# --- Job search aggregator APIs ---
# Adzuna developer account: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# JSearch via RapidAPI (free tier, monthly cap): https://rapidapi.com/
JSEARCH_RAPIDAPI_KEY=

# RemoteOK and Arbeitnow require no API key (left out intentionally)

# --- Database ---
# Local Docker Compose default (see docker-compose.yml). Swap for a
# Supabase/Neon connection string when deploying.
DATABASE_URL=postgresql+psycopg2://careerforge:careerforge@db:5432/careerforge

# --- Cache / Queue broker ---
# Local Docker Compose default. Swap for an Upstash Redis URL when deploying.
REDIS_URL=redis://redis:6379/0

# --- App ---
APP_ENV=development
